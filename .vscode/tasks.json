{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build.sh",
            "args": [
                "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "catkin_build",
            "type": "shell",
            "command": "catkin build --cmake-args -DCMAKE_BUILD_TYPE=Debug",
            "options": {
                "cwd": "/root/catkin_ws"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "build"
        },
        {
            "label": "catkin_clean",
            "type": "shell",
            "command": "catkin clean --yes",
            "options": {
                "cwd": "/root/catkin_ws"
            },
            "problemMatcher": []
        },
    ]
}